; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited if needed.

[application]

config/name="Dois Mundos"
config/description="A life simulation game about social inequality — two characters, same dream, different starting conditions."
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")

[autoload]

GameClock="*res://autoloads/GameClock.gd"
GameState="*res://autoloads/GameState.gd"
EventBus="*res://autoloads/EventBus.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

